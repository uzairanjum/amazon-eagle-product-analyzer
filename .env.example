# Supabase Configuration
# TODO: Replace with your actual Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key

# Keepa API Configuration
# TODO: Get your API key from https://keepa.com/
# Keepa offers free tier (1 request/second) and paid plans
KEEPA_API_KEY=your-keepa-api-key
KEEPA_DOMAIN=1  # 1 = Amazon.com, 2 = Amazon.co.uk, etc.

# Application Settings
APP_ENV=development  # development, staging, production
APP_HOST=0.0.0.0
APP_PORT=8000

# Rate Limiting
# Keepa free tier: 1 request/second
# This delay helps avoid rate limiting
KEEPA_REQUEST_DELAY=1.0

# Feature Flags
ENABLE_MOCK_DATA=false  # Set to true for testing without Keepa API
